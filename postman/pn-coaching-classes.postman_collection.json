{
  "info": {
    "_postman_id": "pn-coaching-classes",
    "name": "Pranita Nasare Coaching Classes - APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "jwt", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@pncoaching.local\",\n  \"password\": \"Admin@12345\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Students",
      "item": [
        {
          "name": "Submit Admission (multipart)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/students/students",
              "host": ["{{baseUrl}}"],
              "path": ["api", "students", "students"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "fullName", "value": "Test Student", "type": "text" },
                { "key": "classLevel", "value": "10th", "type": "text" },
                { "key": "schoolName", "value": "Test School", "type": "text" },
                { "key": "parentName", "value": "Test Parent", "type": "text" },
                { "key": "phoneNumber", "value": "9876543210", "type": "text" },
                { "key": "email", "value": "student@example.com", "type": "text" },
                { "key": "address", "value": "Test Address", "type": "text" },
                { "key": "documents", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "List Students (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/students/students?limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["api", "students", "students"],
              "query": [{ "key": "limit", "value": "50" }]
            }
          }
        },
        {
          "name": "Update Status (admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/students/students/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "students", "students", ":id", "status"]
            },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"approved\"\n}" }
          }
        },
        {
          "name": "Analytics Summary (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/students/students/analytics/summary",
              "host": ["{{baseUrl}}"],
              "path": ["api", "students", "students", "analytics", "summary"]
            }
          }
        }
      ]
    }
  ]
}

